#!/bin/bash
#
# SPDX-FileCopyrightText: 2026 Alex Turbov <i.zaufi@gmail.com>
# SPDX-License-Identifier: GPL-3.0-or-later
#

set -e

declare -x _bash_on_trace
if [[ $- == *x* ]]; then
    _bash_on_trace='-x'
fi

declare -r _INSTALL_LIBEXEC_DIR='@CMAKE_INSTALL_FULL_LIBEXECDIR@/@PROJECT_NAME@'
declare -r _SCRIPT_DIR="$(dirname "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)")"

if [[ -r "${_SCRIPT_DIR}"/@PROJECT_NAME@-functions.sh ]]; then
    # shellcheck source=smart-prompt-functions.sh
    . "${_SCRIPT_DIR}"/@PROJECT_NAME@-functions.sh
else
    # shellcheck source=smart-prompt-functions.sh
    . "${_INSTALL_LIBEXEC_DIR}"/@PROJECT_NAME@-functions.sh
fi

if [[ -r "${_SCRIPT_DIR}"/cdui-feed.sh ]]; then
    declare -rx _FEED_SCRIPT="${_SCRIPT_DIR}"/cdui-feed.sh
else
    declare -rx _FEED_SCRIPT="${_INSTALL_LIBEXEC_DIR}"/cdui-feed.sh
fi

declare -x _cdui_url_color
declare -x _cdui_reset_color
_eval_ansi_color_string "reset ${SP_CDUI_URL_COLOR:-cyan italic}" _cdui_url_color
_eval_ansi_color_string 'reset' _cdui_reset_color

# shellcheck disable=SC2016
declare -rx _JQ_TABLE='
  def pad($w): . + (" " * ($w - (. | length)));
  def color_url($prefix; $suffix): $prefix + . + $suffix;
  def pluralize($count; $unit): "\($count) \($unit)\(if $count == 1 then "" else "s" end) ago";
  def ago_time:
    . as $timestamp
    | (now - $timestamp | floor) as $elapsed
    | if $elapsed <= 0 then "just now"
      elif $elapsed < 60 then pluralize($elapsed; "second")
      elif $elapsed < 3600 then pluralize(($elapsed / 60 | floor); "minute")
      elif $elapsed < 86400 then pluralize(($elapsed / 3600 | floor); "hour")
      elif $elapsed < 604800 then pluralize(($elapsed / 86400 | floor); "day")
      elif $elapsed < 2592000 then pluralize(($elapsed / 604800 | floor); "week")
      elif $elapsed < 31536000 then pluralize(($elapsed / 2592000 | floor); "month")
      else pluralize(($elapsed / 31536000 | floor); "year")
      end;
  def entry_to_display:
    if type == "number" then
      ago_time
    elif type == "string" and test("^[0-9]{10}(\\.[0-9]+)?$") then
      tonumber | ago_time
    else
      tostring
    end;

  map([.origin, (.entry | entry_to_display), .url]) as $rows
  | [
      ($rows | map(.[0] | length) | max),
      ($rows | map(.[1] | length) | max),
      ($rows | map(.[2] | length) | max)
    ] as $w
  | $rows[]
  | [
      (.[0] | pad($w[0])),
      (.[1] | pad($w[1])),
      (.[2] | pad($w[2]) | color_url($url_color_prefix; $url_color_suffix)),
      .[2]
    ]
  | @tsv
'

function cdui_cache_dir()
{
    echo "${XDG_CACHE_HOME:-${HOME}/.cache}"/smart-prompt
}
export -f cdui_cache_dir

function _cdui_format_table()
{
    jq -r \
      --arg url_color_prefix "${_cdui_url_color}" \
      --arg url_color_suffix "${_cdui_reset_color}" \
      "${_JQ_TABLE}"
}
export -f _cdui_format_table

function _cdui_mc_hotlist()
{
    # shellcheck disable=SC2086,SC2154
    bash ${_bash_on_trace} "${_FEED_SCRIPT}" --mc-hotlist | _cdui_format_table
}
export -f _cdui_mc_hotlist

function _cdui_recents()
{
    # shellcheck disable=SC2086,SC2154
    bash ${_bash_on_trace} "${_FEED_SCRIPT}" --recent | _cdui_format_table

}
export -f _cdui_recents

function _cdui_git_worktrees()
{
    # shellcheck disable=SC2086,SC2154
    bash ${_bash_on_trace} "${_FEED_SCRIPT}" --git-worktrees | _cdui_format_table

}
export -f _cdui_git_worktrees

declare _selected_dir
_selected_dir=$(
    # shellcheck disable=SC2154
    _cdui_mc_hotlist \
      | sk \
            --ansi \
            --delimiter $'\t' \
            --with-nth 1,2,3 \
            --prompt='📁 Select a directory to jump into〉' \
            --border=rounded \
            --bind="ctrl-t:reload(bash -c _cdui_recents)" \
            --bind="ctrl-h:reload(bash -c _cdui_mc_hotlist)" \
            --bind="ctrl-g:reload(bash -c _cdui_git_worktrees)" \
            --header $'🅲🆃🆁🅻-🆃 recent dirs 🔁    🅲🆃🆁🅻-🅷 hot dirs 🔥    🅲🆃🆁🅻+🅶 Git work trees ' \
      | cut -f4
  )

if [[ -n ${_selected_dir} ]]; then
    # shellcheck disable=SC2086
    bash ${_bash_on_trace} "${_FEED_SCRIPT}" --update "${_selected_dir}"
    printf '%s\n' "${_selected_dir}"
fi
