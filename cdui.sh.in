#!/bin/bash
#
# SPDX-FileCopyrightText: 2026 Alex Turbov <i.zaufi@gmail.com>
# SPDX-License-Identifier: GPL-3.0-or-later
#

set -e

declare -x _bash_on_trace
if [[ $- == *x* ]]; then
    _bash_on_trace='-x'
fi

declare -r _INSTALL_LIBEXEC_DIR='@CMAKE_INSTALL_FULL_LIBEXECDIR@/@PROJECT_NAME@'
declare -r _SCRIPT_DIR="$(dirname "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)")"

if [[ -r "${_SCRIPT_DIR}"/@PROJECT_NAME@-functions.sh ]]; then
    # shellcheck source=smart-prompt-functions.sh
    . "${_SCRIPT_DIR}"/@PROJECT_NAME@-functions.sh
else
    # shellcheck source=smart-prompt-functions.sh
    . "${_INSTALL_LIBEXEC_DIR}"/@PROJECT_NAME@-functions.sh
fi

if [[ -r "${_SCRIPT_DIR}"/build/charmaps.sh ]]; then
    # shellcheck source=/dev/null
    . "${_SCRIPT_DIR}"/build/charmaps.sh
else
    # shellcheck source=/dev/null
    . "${_INSTALL_LIBEXEC_DIR}"/charmaps.sh
fi

if [[ -r "${_SCRIPT_DIR}"/cdui-feed.sh ]]; then
    declare -rx _FEED_SCRIPT="${_SCRIPT_DIR}"/cdui-feed.sh
else
    declare -rx _FEED_SCRIPT="${_INSTALL_LIBEXEC_DIR}"/cdui-feed.sh
fi

declare -x _cdui_url_color
declare -x _cdui_alert_color
declare -x _cdui_reset_color
_eval_ansi_color_string "${SP_CDUI_URL_COLOR:-cyan italic}" _cdui_url_color
_eval_ansi_color_string "${SP_CDUI_MISSED_URL_COLOR:-${SP_COLOR_ALERT:-red italic strike}}" _cdui_alert_color
_eval_ansi_color_string 'reset' _cdui_reset_color

# shellcheck disable=SC2016
declare -rx _JQ_TABLE='
  def pad($w): . + (" " * ($w - (. | length)));
  def color_url($prefix; $suffix): $prefix + . + $suffix;
  def pluralize($count; $unit): "\($count) \($unit)\(if $count == 1 then "" else "s" end) ago";
  def ago_time:
    . as $timestamp
    | (now - $timestamp | floor) as $elapsed
    | if $elapsed <= 0 then "just now"
      elif $elapsed < 60 then pluralize($elapsed; "second")
      elif $elapsed < 3600 then pluralize(($elapsed / 60 | floor); "minute")
      elif $elapsed < 86400 then pluralize(($elapsed / 3600 | floor); "hour")
      elif $elapsed < 604800 then pluralize(($elapsed / 86400 | floor); "day")
      elif $elapsed < 2592000 then pluralize(($elapsed / 604800 | floor); "week")
      elif $elapsed < 31536000 then pluralize(($elapsed / 2592000 | floor); "month")
      else pluralize(($elapsed / 31536000 | floor); "year")
      end;
  def entry_to_display:
    if type == "number" then
      ago_time
    elif type == "string" and test("^[0-9]{10}(\\.[0-9]+)?$") then
      tonumber | ago_time
    else
      tostring
    end;

  map(.url = if .url == $pwd then "" else .url end)
  | map([.origin, (.entry | entry_to_display), .url, (.missing_url // false)]) as $rows
  | [
      ($rows | map(.[0] | length) | max),
      ($rows | map(.[1] | length) | max)
    ] as $w
  | $rows[]
  | [
      (.[0] | pad($w[0])),
      (.[1] | pad($w[1])),
      (
        .[2] as $url
        | if .[3] then
            ($url | color_url($alert_color_prefix; $url_color_suffix))
          else
            ($url | color_url($url_color_prefix; $url_color_suffix))
          end
      ),
      .[2]
    ]
  | @tsv
'

function cdui_cache_dir()
{
    echo "${XDG_CACHE_HOME:-${HOME}/.cache}"/smart-prompt
}
export -f cdui_cache_dir

function _cdui_format_table()
{
    jq -r \
      --arg pwd "${PWD}" \
      --arg alert_color_prefix "${_cdui_alert_color}" \
      --arg url_color_prefix "${_cdui_url_color}" \
      --arg url_color_suffix "${_cdui_reset_color}" \
      "${_JQ_TABLE}"
}
export -f _cdui_format_table

function _cdui_mark_missing_dirs()
{
    local _item
    local _url
    local _missing
    local -a _items=()

    while IFS= read -r _item; do
        _url=$(jq -r '.url // ""' <<< "${_item}")
        _missing=false
        if [[ -n ${_url} && ! -d ${_url} ]]; then
            _missing=true
        fi

        _items+=( "$(jq -c --argjson missing "${_missing}" '. + {missing_url: $missing}' <<< "${_item}")" )
    done < <(jq -c '.[]')

    if ((${#_items[@]} == 0)); then
        printf '[]\n'
        return 0
    fi

    printf '%s\n' "${_items[@]}" | jq -s '.'
}
export -f _cdui_mark_missing_dirs

function _cdui_feed()
{
    local -r _cli_option="$1"

    # shellcheck disable=SC2086,SC2154
    bash ${_bash_on_trace} "${_FEED_SCRIPT}" "${_cli_option}" | _cdui_mark_missing_dirs | _cdui_format_table
}
export -f _cdui_feed

function _cdui_get_ui_hints()
{
    # shellcheck disable=SC2086,SC2154
    {
        bash ${_bash_on_trace} "${_FEED_SCRIPT}" --mc-hotlist --ui-hints
        bash ${_bash_on_trace} "${_FEED_SCRIPT}" --recent --ui-hints
        bash ${_bash_on_trace} "${_FEED_SCRIPT}" --git-worktrees --ui-hints
        bash ${_bash_on_trace} "${_FEED_SCRIPT}" --env --ui-hints
    } | jq -s 'add // []'
}
export -f _cdui_get_ui_hints

function _cdui_hotkey_to_bind_key()
{
    local -r _hotkey="$1"

    echo "${_hotkey,,}" | tr '+' '-'
}
export -f _cdui_hotkey_to_bind_key

function _cdui_make_header()
{
    local _header=
    local _part

    for _part in "${_cdui_header_parts[@]}"; do
        if [[ -n ${_header} ]]; then
            _header+=' · '
        fi
        _header+="${_part}"
    done

    printf '%s\n' "${_header}"
}
export -f _cdui_make_header

declare -a _cdui_reload_bindings=()
declare -a _cdui_header_parts=()
declare _cdui_initial_cli_option=

while IFS=$'\t' read -r _hotkey _text _cli_option; do
    if [[ -z ${_hotkey} || -z ${_text} || -z ${_cli_option} ]]; then
        continue
    fi

    if [[ -z ${_cdui_initial_cli_option} ]]; then
        _cdui_initial_cli_option=${_cli_option}
    fi

    _cdui_reload_bindings+=("--bind=$(_cdui_hotkey_to_bind_key "${_hotkey}"):reload(bash -c '_cdui_feed ${_cli_option}')")
    _cdui_header_parts+=("$(text2squarefilled "${_hotkey}") $(text2small_caps "${_text}")")
done < <(
    _cdui_get_ui_hints \
      | jq -r '.[] | [.hotkey, .text, .cli_option] | @tsv'
  )

if [[ -z ${_cdui_initial_cli_option} ]]; then
    _cdui_initial_cli_option=--mc-hotlist
fi

declare _selected_dir
_selected_dir=$(
    # shellcheck disable=SC2154
    _cdui_feed "${_cdui_initial_cli_option}" \
      | sk \
            --ansi \
            --delimiter $'\t' \
            --with-nth 1,2,3 \
            --prompt='📁 Select a directory to jump into〉' \
            --border=rounded \
            "${_cdui_reload_bindings[@]}" \
            --header "$(_cdui_make_header)" \
      | cut -f4
  )

if [[ -n ${_selected_dir} ]]; then
    # shellcheck disable=SC2086
    bash ${_bash_on_trace} "${_FEED_SCRIPT}" --update "${_selected_dir}"
    printf '%s\n' "${_selected_dir}"
fi
